# Required Configuration
HUAWEI_ROUTER_IP_ADDRESS="192.168.8.1"
HUAWEI_ROUTER_ACCOUNT="admin"
HUAWEI_ROUTER_PASSWORD=""
PUSHOVER_TOKEN=""
PUSHOVER_USER=""
ROUTER_NAME="My Router"

# Optional Configuration
LOCALE="en_US"

# Retry Settings
MAX_RETRIES="3"
RETRY_DELAY="5"

# Message Processing
MAX_MESSAGES="10"

# SMS Retention - Auto-delete successfully sent messages after X days (default: 30)
# Set to 0 to disable automatic deletion
SMS_RETENTION_DAYS="30"

# Dry Run Mode (set to "true" to test without marking messages as read)
DRY_RUN="false"

# Filtering Options (comma-separated values)
# Filter by phone numbers (only process SMS from these numbers)
FILTER_PHONES=""
# Example: FILTER_PHONES="+1234567890,+0987654321"

# Filter by keywords (only process SMS containing these keywords)
FILTER_KEYWORDS=""
# Example: FILTER_KEYWORDS="urgent,important,alert"

# PushOver Advanced Options
# Priority: -2 (lowest) to 2 (emergency). Default: 0
PUSHOVER_PRIORITY="0"

# Sound: Custom notification sound (see PushOver API docs for options)
# Examples: pushover, bike, bugle, cashregister, classical, cosmic, falling,
#           gamelan, incoming, intermission, magic, mechanical, pianobar,
#           siren, spacealarm, tugboat, alien, climb, persistent, echo, updown, none
PUSHOVER_SOUND=""

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# Docker Settings
# POLL_INTERVAL: how often to check for SMS, in seconds (e.g. 10, 30, 60, 300)
POLL_INTERVAL="10"
RUN_ON_START="true"
